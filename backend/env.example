# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/traffic_control
MONGODB_USER=
MONGODB_PASSWORD=

# JWT密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,audio/mpeg,audio/wav,audio/m4a

# 加密密钥（用于敏感数据加密，32字节）
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS配置
CORS_ORIGIN=http://localhost:5173

# AI模型配置（后续集成）
AI_API_URL=
AI_API_KEY=
